{
    "name": "rodrigocborges/facilphp",
    "type": "project",
    "description": "A dev-friendly, file-based routing PHP framework.",
    "keywords": ["framework", "php", "routing", "micro-saas"],
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Facil\\": "src/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "start-dev": "php -S localhost:8000 -t public",
        "start-prod": "php -S 0.0.0.0:80 -t public"
    }
}